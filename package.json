{
  "name": "walking-library",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm install && npm --prefix walking-library install",
    "setup:frontend": "npm --prefix walking-library install",
    "setup:backend": "cd bookapp && gradlew.bat dependencies",
    "dev": "npm run setup && concurrently -n backend,frontend -c cyan,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd bookapp && gradlew.bat bootRun",
    "dev:frontend": "npm --prefix walking-library run dev",
    "build": "npm --prefix walking-library run build && cd bookapp && gradlew.bat build",
    "lint": "npm --prefix walking-library run lint",
    "preview": "npm --prefix walking-library run preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "json-server": "^0.17.4",
    "vite": "^8.0.12"
  }
}
